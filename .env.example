# =============================================================================
# ConferaSystems — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit real secrets. Set production values in Vercel's Environment
# Variables dashboard (or your preferred secrets manager).
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# Supabase connection string (Transaction pooler recommended for serverless)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]?pgbouncer=true&connection_limit=1
# Get from: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase direct connection (used for migrations only — NOT pooled)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
# DIRECT_URL is used by `prisma migrate deploy` and NOT set in Vercel runtime env.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# --- Authentication (NextAuth v5) --------------------------------------------
# Random secret used to sign JWTs and cookies.
# Generate with: openssl rand -base64 32
# Auth.js v5 also accepts NEXTAUTH_SECRET as a fallback.
AUTH_SECRET="replace-with-a-random-32-char-string"

# Public URL of this application (no trailing slash).
# Vercel sets VERCEL_URL automatically — this variable overrides it for custom domains.
# Required for OAuth redirect URIs and absolute link generation.
NEXTAUTH_URL="https://your-app.vercel.app"

# --- Email (Resend) -----------------------------------------------------------
# API key for sending transactional emails (booking confirmations, etc.)
# Create at: https://resend.com/api-keys
# If not set, email sending is silently skipped (safe for local dev/staging).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# From address used in outbound emails. Must be a verified Resend sender.
EMAIL_FROM="noreply@yourdomain.com"

# --- Node.js -----------------------------------------------------------------
# Set to "production" in Vercel automatically. Do not override.
# NODE_ENV="production"
