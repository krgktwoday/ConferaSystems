# =============================================================================
# ConferaSystems — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# The Docker Compose values below work out-of-the-box with:
#   docker compose up -d
#
# NEVER commit real secrets. Set production values in Vercel's Environment
# Variables dashboard (or your preferred secrets manager).
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# LOCAL DOCKER (docker-compose.yml):
#   docker compose up -d   →   Postgres available at localhost:5433
#   (port 5433 used to avoid conflict with other local Postgres instances)
DATABASE_URL="postgresql://confera:confera_dev@localhost:5433/confera_platform"

# PRODUCTION (Supabase — Transaction pooler, port 6543):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# --- Authentication (NextAuth v5) --------------------------------------------
# Random secret used to sign JWTs and cookies.
# Generate with: openssl rand -base64 32
# Auth.js v5 also accepts NEXTAUTH_SECRET as a fallback.
AUTH_SECRET="dev-secret-change-me-in-production"

# Public URL of this application (no trailing slash).
# Local dev:
NEXTAUTH_URL="http://localhost:3000"
# Production: set to your Vercel URL, e.g. "https://your-app.vercel.app"

# --- Email (Resend) -----------------------------------------------------------
# API key for sending transactional emails (booking confirmations, etc.)
# If not set, email sending is silently skipped — safe for local dev.
# Create at: https://resend.com/api-keys
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# From address used in outbound emails. Must be a verified Resend sender.
# EMAIL_FROM="noreply@yourdomain.com"

# --- Node.js -----------------------------------------------------------------
# Set to "production" in Vercel automatically. Do not override in production.
# NODE_ENV="development"
