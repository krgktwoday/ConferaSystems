// Prisma schema for Hotel/Venue Platform
// Sprint 1 core domain models: Property, User, Room, Booking
// Sprint 2 addition: Facility model (Module A — Facility Management)
// Sprint 3 addition: Booking engine — BookingType, BookingFacility junction (CON-13)
// Sprint 4 addition: Staff & Shift Scheduling (CON-14) — StaffRole, contractedHours,
//   ShiftStatus, LeaveRequest, ShiftSwap, StaffingRule
// See CON-4 for schema design decisions.

generator client {
  provider = "prisma-client-js"
}

// NOTE: datasource URL is managed via prisma.config.ts (Prisma 7 style).
// The `datasource db` block here only declares the provider for type generation.
datasource db {
  provider = "postgresql"
}

// ─── Core Domain: Sprint 1 ────────────────────────────────────────────────────

model Property {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  rooms          Room[]
  bookings       Booking[]
  staff          Staff[]
  facilities     Facility[]
  staffingRules  StaffingRule[]

  @@index([slug])
}

model User {
  id           String   @id @default(cuid())
  propertyId   String
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  staff    Staff?
  // NextAuth v5 — kept for future OAuth provider support
  accounts Account[]

  // Unique email per property (multi-tenant scoping)
  @@unique([email, propertyId])
  @@index([propertyId])
}

// NextAuth Account model (required by @auth/prisma-adapter; used for OAuth flows)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

enum UserRole {
  ADMIN
  STAFF
  VIEWER
}

model Room {
  id          String     @id @default(cuid())
  propertyId  String
  name        String
  type        RoomType   @default(BEDROOM)
  capacity    Int        @default(1)
  description String?
  status      RoomStatus @default(AVAILABLE)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  property     Property       @relation(fields: [propertyId], references: [id])
  bookings     Booking[]
  availability Availability[]

  // Composite index for availability queries
  @@index([propertyId, status])
}

enum RoomType {
  BEDROOM
  CONFERENCE
  EVENT
}

enum RoomStatus {
  AVAILABLE
  MAINTENANCE
  INACTIVE
}

// ─── Sprint 2: Facility Management (Module A) ─────────────────────────────────

/// A physical space managed by a property (room, conference hall, outdoor area, etc.)
model Facility {
  id           String         @id @default(cuid())
  propertyId   String
  name         String
  type         FacilityType   @default(ROOM)
  maxCapacity  Int            @default(1)
  description  String?
  /// JSON array of equipment strings e.g. ["projector","whiteboard"]
  equipment    String[]
  cateringZone String?
  status       FacilityStatus @default(AVAILABLE)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  property         Property          @relation(fields: [propertyId], references: [id])
  bookingFacilities BookingFacility[]

  @@index([propertyId, status])
  @@index([propertyId, deletedAt])
}

enum FacilityType {
  ROOM
  CONFERENCE_HALL
  EVENT_SPACE
  OUTDOOR
}

enum FacilityStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

// ─── Sprint 3: Booking Engine (Module B, CON-13) ──────────────────────────────

model Booking {
  id         String        @id @default(cuid())
  propertyId String
  /// Legacy room link — kept for backward compat; new bookings use BookingFacility
  roomId     String?
  guestName  String
  guestEmail String?
  checkIn    DateTime
  checkOut   DateTime
  type       BookingType   @default(STAY)
  status     BookingStatus @default(PENDING)
  totalPrice Decimal       @db.Decimal(10, 2)
  notes      String?
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  property          Property          @relation(fields: [propertyId], references: [id])
  room              Room?             @relation(fields: [roomId], references: [id])
  invoices          Invoice[]
  bookingFacilities BookingFacility[]

  // Compound index for availability range queries
  @@index([propertyId, checkIn, checkOut])
  @@index([propertyId, status])
  @@index([roomId])
  @@index([status])
}

/// Junction table linking a booking to one or more facilities (multi-facility booking)
model BookingFacility {
  id         String   @id @default(cuid())
  bookingId  String
  facilityId String
  createdAt  DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id])

  @@unique([bookingId, facilityId])
  @@index([bookingId])
  @@index([facilityId])
}

enum BookingType {
  STAY
  CONFERENCE
  EVENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ─── Extended Models (Sprint 2+) ──────────────────────────────────────────────

model Availability {
  id            String   @id @default(cuid())
  roomId        String
  date          DateTime @db.Date
  isAvailable   Boolean  @default(true)
  blockedReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id])

  @@unique([roomId, date])
  @@index([roomId, date])
}

// ─── Sprint 4: Staff & Shift Scheduling (Module C, CON-14) ───────────────────

/// Staff role determines scheduling rules and portal access.
enum StaffRole {
  WAITER
  RECEPTIONIST
  CLEANING
  MANAGER
  KITCHEN
}

/// Status lifecycle for a shift.
enum ShiftStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

/// Status for leave requests and shift swap proposals.
enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Full staff profile — extends the User with scheduling attributes.
model Staff {
  id              String    @id @default(cuid())
  propertyId      String
  userId          String    @unique
  name            String
  email           String
  staffRole       StaffRole @default(WAITER)
  contractedHours Int       @default(40) // weekly hours
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property      Property       @relation(fields: [propertyId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  shifts        Shift[]
  leaveRequests LeaveRequest[]
  swapsProposed ShiftSwap[]    @relation("SwapProposer")
  swapsTargeted ShiftSwap[]    @relation("SwapTarget")

  @@index([propertyId])
  @@index([propertyId, staffRole])
}

/// A scheduled work period for a staff member.
model Shift {
  id         String      @id @default(cuid())
  propertyId String
  staffId    String
  facilityId String?     // optional: shift is tied to a specific facility
  startsAt   DateTime
  endsAt     DateTime
  status     ShiftStatus @default(SCHEDULED)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  staff          Staff       @relation(fields: [staffId], references: [id])
  swapsAsOrigin  ShiftSwap[] @relation("SwapOriginShift")
  swapsAsTarget  ShiftSwap[] @relation("SwapTargetShift")

  @@index([propertyId])
  @@index([staffId])
  @@index([startsAt])
  @@index([propertyId, startsAt, endsAt])
}

/// Leave request submitted by staff; approved/rejected by ADMIN.
model LeaveRequest {
  id         String        @id @default(cuid())
  propertyId String
  staffId    String
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  status     RequestStatus @default(PENDING)
  reviewedBy String?       // userId of the ADMIN who acted
  reviewedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([propertyId])
  @@index([staffId])
  @@index([propertyId, status])
}

/// Shift swap proposal: proposer wants to swap their shift with target staff's shift.
model ShiftSwap {
  id              String        @id @default(cuid())
  propertyId      String
  proposerId      String        // staffId of initiator
  targetStaffId   String        // staffId of the other party
  proposerShiftId String        // shift the proposer offers
  targetShiftId   String        // shift the proposer wants in return
  status          RequestStatus @default(PENDING)
  reviewedBy      String?       // userId of ADMIN who approved/rejected
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  proposer      Staff @relation("SwapProposer", fields: [proposerId], references: [id])
  targetStaff   Staff @relation("SwapTarget", fields: [targetStaffId], references: [id])
  proposerShift Shift @relation("SwapOriginShift", fields: [proposerShiftId], references: [id])
  targetShift   Shift @relation("SwapTargetShift", fields: [targetShiftId], references: [id])

  @@index([propertyId])
  @@index([proposerId])
  @@index([targetStaffId])
  @@index([propertyId, status])
}

/// Per-tenant staffing suggestion rules: how many staff of each role per guest count.
model StaffingRule {
  id              String    @id @default(cuid())
  propertyId      String
  staffRole       StaffRole
  guestsPerStaff  Int       @default(10) // 1 staff member per N guests
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, staffRole])
  @@index([propertyId])
}

model Invoice {
  id         String        @id @default(cuid())
  propertyId String
  bookingId  String
  amount     Decimal       @db.Decimal(10, 2)
  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([propertyId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}
